<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main Content -->

    <!-- Navigation Drawer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scheme1.2">

        <!-- Toolbar added for hamburger icon and title -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/scheme3.3"
            android:elevation="4dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            android:title="My App"
            android:titleTextColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:title="Dashboard" />

        <!-- Temperature Container -->
        <TextView
            android:id="@+id/handa_temp"
            android:layout_width="330dp"
            android:layout_height="70dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/border_radius2"
            android:gravity="center"
            android:text="H    A    N    D    A"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.506"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar" />

        <LinearLayout
            android:id="@+id/disp_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/handa_temp">


            <LinearLayout
                android:layout_width="350dp"
                android:layout_height="95dp"
                android:background="@color/scheme1.2"
                android:gravity="center">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/blue_square"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingLeft="10dp"
                            android:paddingTop="5dp"
                            app:srcCompat="@drawable/baseline_square_blue" />

                        <TextView
                            android:id="@+id/blue_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:paddingTop="2dp"
                            android:text="Normal:Safe, No signs of fire or danger."
                            android:textAlignment="center"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/orange_square"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingLeft="10dp"
                            android:paddingTop="5dp"
                            app:srcCompat="@drawable/baseline_square_orng" />

                        <TextView
                            android:id="@+id/orange_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Caution: Abnormal signs detected. Stay alert and ready to respond."

                            android:textSize="12sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/red_square"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingLeft="10dp"
                            android:paddingTop="5dp"
                            app:srcCompat="@drawable/baseline_square_red" />


                        <TextView
                            android:id="@+id/red_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Warning: All abnormal indicators present. Immediate action and evacuation required."
                            android:textSize="12sp" />


                    </LinearLayout>


                </LinearLayout>


            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/temp_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/disp_container">

            <TextView
                android:id="@+id/temp_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="@string/temp"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/temp_card"
                android:layout_width="330dp"
                android:layout_height="100dp"
                android:background="@drawable/border_radius"
                android:gravity="center">

                <ImageView
                    android:id="@+id/temp_disp"
                    android:layout_width="65dp"
                    android:layout_height="137dp"
                    android:layout_marginEnd="15dp"
                    android:src="@drawable/baseline_device_thermostat_24" />

                <TextView
                    android:id="@+id/temp_value_disp"
                    android:layout_width="145dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/temp_value"
                    android:textSize="38sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Humidity Container -->
        <LinearLayout
            android:id="@+id/humid_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/temp_container">

            <TextView
                android:id="@+id/humid_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="@string/humidity"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/humid_card"
                android:layout_width="330dp"
                android:layout_height="100dp"
                android:background="@drawable/border_radius"
                android:gravity="center">

                <ImageView
                    android:id="@+id/humidity_disp"
                    android:layout_width="62dp"
                    android:layout_height="97dp"
                    android:layout_marginEnd="15dp"
                    android:src="@drawable/baseline_water_drop_24" />

                <TextView
                    android:id="@+id/humidity_value_disp"
                    android:layout_width="145dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/humidity_value"
                    android:textSize="38sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Smoke Container -->
        <LinearLayout
            android:id="@+id/smoke_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/humid_container">

            <TextView
                android:id="@+id/smoke_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="@string/smoke"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/smoke_card"
                android:layout_width="330dp"
                android:layout_height="100dp"
                android:background="@drawable/border_radius"
                android:gravity="center">

                <ImageView
                    android:id="@+id/smoke_disp"
                    android:layout_width="62dp"
                    android:layout_height="97dp"
                    android:layout_marginEnd="15dp"
                    android:src="@drawable/baseline_waves_24" />

                <TextView
                    android:id="@+id/smoke_value_disp"
                    android:layout_width="145dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/smoke_value"
                    android:textSize="38sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header" />
</androidx.drawerlayout.widget.DrawerLayout>
